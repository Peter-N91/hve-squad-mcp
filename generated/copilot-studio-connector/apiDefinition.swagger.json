{
  "swagger": "2.0",
  "info": {
    "title": "hve-squad (squad-guided / embedded)",
    "description": "Calls the hve-squad MCP server (squad-guided / embedded). The squad runs server-side under its gates and methodology; this connector exposes squad_research, squad_plan, squad_review, squad_architect, squad_run, squad_status, squad_render_pptx.",
    "version": "1.0"
  },
  "host": "<SQUAD_MCP_HOST>",
  "basePath": "/",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/mcp": {
      "post": {
        "summary": "hve-squad MCP (squad-guided / embedded)",
        "description": "Streamable HTTP MCP endpoint. squad-guided / embedded.",
        "operationId": "InvokeMCP",
        "x-ms-agentic-protocol": "mcp-streamable-1.0",
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "securityDefinitions": {
    "entra-oauth2": {
      "type": "oauth2",
      "flow": "accessCode",
      "authorizationUrl": "https://login.microsoftonline.com/<ENTRA_TENANT_ID>/oauth2/v2.0/authorize",
      "tokenUrl": "https://login.microsoftonline.com/<ENTRA_TENANT_ID>/oauth2/v2.0/token",
      "scopes": {
        "Squad.Research": "Invoke squad_research",
        "Squad.Plan": "Invoke squad_plan",
        "Squad.Review": "Invoke squad_review",
        "Squad.Architect": "Invoke squad_architect",
        "Squad.Run": "Invoke squad_status",
        "Squad.Render": "Invoke squad_render_pptx"
      }
    }
  },
  "security": [
    {
      "entra-oauth2": []
    }
  ]
}
